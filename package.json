{
  "name": "panificadora-rei-dos-paes",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local db/seed.ts",
    "migrate:validate": "tsx --env-file=.env.local scripts/validate-migration.ts",
    "desktop:dev": "concurrently -k -n NEXT,ELECTRON -c blue,magenta \"next dev --turbopack\" \"wait-on tcp:3000 && node desktop/launch.cjs\"",
    "desktop:icon": "node scripts/generate-icon.cjs",
    "desktop:build": "node scripts/generate-icon.cjs && cross-env BUILD_TARGET=desktop next build && node desktop/prepare-standalone.cjs",
    "desktop:dist": "npm run desktop:build && electron-builder --win",
    "desktop:pack": "npm run desktop:build && electron-builder --win --dir"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.30",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "vaul": "^1.1.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.reidospaes.painel",
    "productName": "Painel Padaria",
    "copyright": "Copyright © 2026 Rei dos Pães",
    "directories": {
      "output": "dist-desktop",
      "buildResources": "desktop/build-resources"
    },
    "files": [
      "desktop/main.cjs",
      "desktop/build-resources/icon.ico",
      ".next/standalone/**/*",
      "package.json",
      "!**/.env*",
      "!.git/**/*",
      "!node_modules/**/*"
    ],
    "asar": false,
    "win": {
      "icon": "desktop/build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Painel Padaria"
    }
  }
}
