# ==========================================================================
# Panificadora Rei dos Pães — variáveis de ambiente
# Copie para .env.local e preencha. Nunca commite .env.local.
# ==========================================================================

# === Banco de dados (Neon PostgreSQL) ===
# Connection string do projeto Neon. Veja https://neon.tech/docs/connect/connect-intro
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# === Auth.js v5 ===
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-uma-string-aleatoria-forte-min-32-chars"

# Em desenvolvimento: http://localhost:3000
# Em produção: https://reidospaes.ezzedev.com.br
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# === Upload de imagens (Vercel Blob) ===
# Obrigatório em produção. Em dev, se vazio, usa filesystem local.
# A Vercel gera esse token automaticamente ao conectar um Blob Store ao projeto.
BLOB_READ_WRITE_TOKEN=""

# === URLs públicas ===
# Em dev: http://localhost:3000
# Em prod: https://reidospaes.ezzedev.com.br
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP="5511999999999"

# === Feature flags ===
NEXT_PUBLIC_ENABLE_3D="true"

# === App mode (desktop install vs deploy publico) ===
# "admin"  → instalação desktop na máquina do cliente (libera /admin, redireciona páginas públicas pro NEXT_PUBLIC_PUBLIC_URL)
# "public" → deploy do cardápio em CF Pages (libera páginas públicas, bloqueia /admin)
# vazio    → modo full (desenvolvimento local, libera tudo). Padrão.
APP_MODE=""

# URL pública do cardápio do cliente — usado quando APP_MODE=admin pra redirecionar visitas em rotas públicas
# Em prod cliente: https://padariax.ezzedev.com.br
# Em dev: http://localhost:3000
NEXT_PUBLIC_PUBLIC_URL="http://localhost:3000"

# === Seed (opcional) ===
SEED_ADMIN_EMAIL="admin@reidospaes.com.br"
SEED_ADMIN_PASSWORD="admin123"
